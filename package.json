{
  "name": "sitectl",
  "version": "0.1.1",
  "author": "Shura Vlasov",
  "description": "CLI toolkit for site operations.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "sitectl": "./dist/index.js"
  },
  "files": [
    "dist",
    "config"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && node dist/index.js",
    "prepare": "npm run build && node scripts/seed-data.mjs",
    "ssh": "npm run build && node dist/index.js ssh",
    "ssh-copy-id": "npm run build && node dist/index.js ssh-copy-id",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
